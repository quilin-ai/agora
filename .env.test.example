# Copy this file to .env.test before running test environment commands.
DATABASE_URL=postgresql://user:password@localhost:5432/agora_test
# For Supabase, prefer the session pooler connection string from the dashboard here.
DATABASE_SESSION_POOLER_URL=
# Optional explicit transaction pooler for short-lived one-shot jobs.
DATABASE_TRANSACTION_POOLER_URL=
# Backward-compatible generic pooler slot.
DATABASE_POOLER_URL=
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_READY_RETRIES=4
DATABASE_READY_RETRY_DELAY_MS=1500
OPENROUTER_API_KEY=your-openrouter-test-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ADMIN_EMAIL=rayson951005@gmail.com
CLI_TEST_USER_ID=00000000-0000-4000-8000-000000000001
AGORA_MODEL_SOURCE=openrouter
AGORA_ALLOWED_MODELS=deepseek/deepseek-chat,qwen/qwen3.5-9b,moonshotai/kimi-k2,z-ai/glm-4.5-air,minimax/minimax-m1
AGORA_DEFAULT_COUNCIL_MODELS=deepseek/deepseek-chat,z-ai/glm-4.5-air,moonshotai/kimi-k2
AGORA_SECRETARY_MODEL=deepseek/deepseek-chat
AGORA_ROUND_SUMMARY_MODEL=minimax/minimax-m1
