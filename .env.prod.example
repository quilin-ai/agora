# Copy this file to .env.prod before running production environment commands.
DATABASE_URL=postgresql://user:password@db-host:5432/agora_prod
# For Supabase, prefer the session pooler connection string from the dashboard here.
DATABASE_SESSION_POOLER_URL=
# Optional explicit transaction pooler for short-lived one-shot jobs.
DATABASE_TRANSACTION_POOLER_URL=
# Backward-compatible generic pooler slot.
DATABASE_POOLER_URL=
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_READY_RETRIES=4
DATABASE_READY_RETRY_DELAY_MS=1500
OPENROUTER_API_KEY=your-openrouter-prod-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ADMIN_EMAIL=rayson951005@gmail.com
CLI_TEST_USER_ID=00000000-0000-4000-8000-000000000001
AGORA_MODEL_SOURCE=openrouter
AGORA_ALLOWED_MODELS=replace-with-production-model-whitelist
AGORA_DEFAULT_COUNCIL_MODELS=replace-with-production-default-council-models
AGORA_SECRETARY_MODEL=replace-with-production-secretary-model
