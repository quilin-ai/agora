DATABASE_URL=postgresql://user:password@localhost:5432/agora
# For Supabase, prefer the session pooler for CLI/seed/runtime stability.
DATABASE_SESSION_POOLER_URL=
# Optional explicit transaction pooler for short-lived serverless-style flows.
DATABASE_TRANSACTION_POOLER_URL=
# Backward-compatible generic pooler slot if you only want to provide one pooler URL.
DATABASE_POOLER_URL=
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_READY_RETRIES=4
DATABASE_READY_RETRY_DELAY_MS=1500
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ADMIN_EMAIL=rayson951005@gmail.com
CLI_TEST_USER_ID=00000000-0000-4000-8000-000000000001
AGORA_MODEL_SOURCE=openrouter
AGORA_ALLOWED_MODELS=openai/gpt-oss-120b:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,google/gemma-3-27b-it:free
AGORA_DEFAULT_COUNCIL_MODELS=openai/gpt-oss-120b:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free
AGORA_SECRETARY_MODEL=openai/gpt-oss-120b:free
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
